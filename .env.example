# ── Lead Triage Demo — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in every value before running docker compose.
# NEVER commit .env — it is gitignored. Only .env.example is committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── n8n ───────────────────────────────────────────────────────────────────────
# The public hostname/IP where n8n will be reachable.
# Use "localhost" for local-only dev. Use your VPS/cloud hostname for remote.
N8N_HOST=localhost

# Port n8n listens on (and maps to on the host).
N8N_PORT=5678

# http or https. Use https when fronted by a reverse proxy (nginx/Caddy).
N8N_PROTOCOL=http

# Full base URL for webhooks. n8n uses this to build webhook callback URLs.
# Must be externally reachable if you want webhooks to work from outside Docker.
# Example local: http://localhost:5678
# Example remote: https://n8n.yourdomain.com
WEBHOOK_URL=http://localhost:5678

# Optional: protect the n8n UI with basic auth.
# Set N8N_BASIC_AUTH_ACTIVE=true and provide credentials.
N8N_BASIC_AUTH_ACTIVE=false
N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_PASSWORD=

# Timezone for n8n execution logs (e.g. America/New_York, Asia/Kolkata, UTC)
GENERIC_TIMEZONE=UTC

# ── LLM (Groq free tier, OpenAI-compatible) ───────────────────────────────────
# Groq: get a free key at https://console.groq.com
# To use Gemini instead: set LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# and LLM_MODEL=gemini-1.5-flash (also free-tier available)
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.1-8b-instant
LLM_API_KEY=<your-groq-api-key-here>

# ── Slack Incoming Webhooks ───────────────────────────────────────────────────
# Create incoming webhooks at: https://api.slack.com/apps → Incoming Webhooks
# Each webhook URL looks like: https://hooks.slack.com/services/T.../B.../...
# You can point multiple tiers at the same webhook during dev/testing.
# #alerts is required; the tier channels can fall back to #alerts if not set
# (the workflow falls back automatically when a tier webhook is not configured).
SLACK_WEBHOOK_HOT=<https://hooks.slack.com/services/YOUR/HOT/WEBHOOK>
SLACK_WEBHOOK_WARM=<https://hooks.slack.com/services/YOUR/WARM/WEBHOOK>
SLACK_WEBHOOK_COLD=<https://hooks.slack.com/services/YOUR/COLD/WEBHOOK>
SLACK_WEBHOOK_ALERTS=<https://hooks.slack.com/services/YOUR/ALERTS/WEBHOOK>
