    {
      "parameters": {
        "jsCode": "// ── Error handler ──────────────────────────────────────────────────────────────\n// Receives the failed item when a node has onError: \"continueErrorOutput\".\n// The item arriving here carries the original data PLUS n8n injects an\n// 'error' object onto the JSON: { message, description, stack, ... }\n//\n// We do NOT reference $env values in the payload or logs — secrets stay out.\n\nconst item = $input.first();\nconst incomingJson = item.json || {};\n\n// n8n injects the error info under .error on the item when continueErrorOutput fires\nconst errorInfo = incomingJson.error || {};\nconst errorMessage = errorInfo.message || incomingJson.errorMessage || 'unknown error';\n\n// Recover the idempotency key from wherever it is still readable.\n// By the time any of the fallible nodes fail, 'Compute Key' has always run.\nlet key = 'unknown';\ntry { key = $('Compute Key').first().json.key || 'unknown'; } catch (_) {}\n\n// Build a safe payload: original lead fields only, no env values, no secrets.\n// Use fields that are safe to store — no raw API keys, no webhook URLs.\nlet safePayload;\ntry {\n  const ck = $('Compute Key').first().json;\n  safePayload = {\n    key: ck.key,\n    email: ck.email,\n    name: ck.name,\n    company: ck.company,\n    source: ck.source\n  };\n} catch (_) {\n  safePayload = { key };\n}\n\nreturn [{ json: { key, errorMessage, safePayload } }];"
      },
