      "parameters": {
        "jsCode": "// ── Step 1: Compute idempotency key ─────────────────────────────────────\nconst crypto = require('crypto');\n\nconst body  = $input.first().json.body  || $input.first().json;\nconst headers = $input.first().json.headers || {};\n\nconst email   = (body.email   || '').trim();\nconst message = (body.message || '').trim();\nconst name    = (body.name    || '').trim();\nconst company = (body.company || '').trim();\nconst source  = (body.source  || '').trim();\n\n// Prefer explicit header; fall back to content hash\nconst headerKey = headers['idempotency-key'] || headers['Idempotency-Key'] || '';\nconst key = headerKey\n  ? headerKey.trim()\n  : crypto.createHash('sha256').update(email + '\\n' + message).digest('hex');\n\nreturn [{ json: { key, email, message, name, company, source, rawBody: body } }];"
      },
      "id": "code-compute-key",
      "name": "Compute Key",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "jsCode": "// ── Step 2: Validate input ──────────────────────────────────────────────\nconst { key, email, message, name, company, source, rawBody } = $input.first().json;\n\nconst emailRegex = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;\nconst emailOk   = email && emailRegex.test(email);\nconst messageOk = message && message.length > 0;\n\nconst valid  = emailOk && messageOk;\nlet reason = '';\nif (!emailOk)   reason += 'missing or invalid email; ';\nif (!messageOk) reason += 'missing message; ';\nreason = reason.trim().replace(/;$/, '');\n\nreturn [{ json: { key, email, message, name, company, source, rawBody, valid, validationReason: reason } }];"
      },
      "id": "code-validate",
      "name": "Validate Input",
      "type": "n8n-nodes-base.code",
